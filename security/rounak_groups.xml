<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Module category ─────────────────────────────────────────── -->
    <record id="module_category_rounak" model="ir.module.category">
        <field name="name">Rounak ERP</field>
        <field name="sequence">50</field>
    </record>

    <!-- ── Security groups (cumulative hierarchy) ──────────────────── -->
    <record id="group_rounak_customer" model="res.groups">
        <field name="name">Customer</field>
        <field name="category_id" ref="module_category_rounak"/>
        <field name="comment">Portal customers — see own company data only.</field>
    </record>

    <record id="group_rounak_sales" model="res.groups">
        <field name="name">Sales</field>
        <field name="category_id" ref="module_category_rounak"/>
        <field name="implied_ids" eval="[(4, ref('group_rounak_customer'))]"/>
        <field name="comment">Sales team — quotes, orders, CRM leads.</field>
    </record>

    <record id="group_rounak_accounts" model="res.groups">
        <field name="name">Accounts</field>
        <field name="category_id" ref="module_category_rounak"/>
        <field name="implied_ids" eval="[(4, ref('group_rounak_customer'))]"/>
        <field name="comment">Accounts / billing team — invoices, payments, credit controls.</field>
    </record>

    <record id="group_rounak_service" model="res.groups">
        <field name="name">Service</field>
        <field name="category_id" ref="module_category_rounak"/>
        <field name="implied_ids" eval="[(4, ref('group_rounak_customer'))]"/>
        <field name="comment">Service / support engineers — helpdesk tickets, fulfillment.</field>
    </record>

    <record id="group_rounak_licensing" model="res.groups">
        <field name="name">Licensing</field>
        <field name="category_id" ref="module_category_rounak"/>
        <field name="implied_ids" eval="[(4, ref('group_rounak_customer'))]"/>
        <field name="comment">License provisioning — distributor portals, license tickets.</field>
    </record>

    <record id="group_rounak_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_rounak"/>
        <field name="implied_ids" eval="[
            (4, ref('group_rounak_sales')),
            (4, ref('group_rounak_accounts')),
            (4, ref('group_rounak_service')),
            (4, ref('group_rounak_licensing')),
        ]"/>
        <field name="comment">Manager — approval authority, all department access.</field>
    </record>

    <record id="group_rounak_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_rounak"/>
        <field name="implied_ids" eval="[(4, ref('group_rounak_manager'))]"/>
        <field name="comment">Full system admin — configuration, rules, audit log.</field>
    </record>
</odoo>
