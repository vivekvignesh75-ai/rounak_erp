<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rounak_control_rule_tree" model="ir.ui.view">
        <field name="name">rounak.control.rule.tree</field>
        <field name="model">rounak.control.rule</field>
        <field name="arch" type="xml">
            <tree string="Control Rules" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <field name="value_float"/>
                <field name="value_char"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_rounak_control_rule_form" model="ir.ui.view">
        <field name="name">rounak.control.rule.form</field>
        <field name="model">rounak.control.rule</field>
        <field name="arch" type="xml">
            <form string="Control Rule">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="category"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="value_float"/>
                            <field name="value_char"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_rounak_control_rule" model="ir.actions.act_window">
        <field name="name">Control Rules</field>
        <field name="res_model">rounak.control.rule</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
