<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rounak_audit_log_tree" model="ir.ui.view">
        <field name="name">rounak.audit.log.tree</field>
        <field name="model">rounak.audit.log</field>
        <field name="arch" type="xml">
            <tree string="Audit Log" create="0" edit="0" delete="0"
                  default_order="create_date desc">
                <field name="create_date" string="Date"/>
                <field name="user_id"/>
                <field name="action" widget="badge"/>
                <field name="summary"/>
                <field name="partner_id" optional="show"/>
                <field name="old_value" optional="hide"/>
                <field name="new_value" optional="hide"/>
                <field name="res_model" optional="hide"/>
                <field name="res_id" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_rounak_audit_log_form" model="ir.ui.view">
        <field name="name">rounak.audit.log.form</field>
        <field name="model">rounak.audit.log</field>
        <field name="arch" type="xml">
            <form string="Audit Log Entry" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="create_date"/>
                            <field name="user_id"/>
                            <field name="action"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="res_model"/>
                            <field name="res_id"/>
                            <field name="old_value"/>
                            <field name="new_value"/>
                        </group>
                    </group>
                    <group>
                        <field name="summary"/>
                        <field name="detail"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_rounak_audit_log_search" model="ir.ui.view">
        <field name="name">rounak.audit.log.search</field>
        <field name="model">rounak.audit.log</field>
        <field name="arch" type="xml">
            <search string="Audit Log">
                <field name="summary"/>
                <field name="user_id"/>
                <field name="partner_id"/>
                <filter name="today" string="Today"
                        domain="[('create_date','>=',context_today().strftime('%%Y-%%m-%%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_action" string="Action" context="{'group_by':'action'}"/>
                    <filter name="group_user" string="User" context="{'group_by':'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_rounak_audit_log" model="ir.actions.act_window">
        <field name="name">Audit Log</field>
        <field name="res_model">rounak.audit.log</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
