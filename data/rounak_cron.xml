<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Check overdue invoices and auto-block partners exceeding threshold -->
    <record id="cron_rounak_overdue_check" model="ir.cron">
        <field name="name">Rounak: Overdue Invoice Auto-Block</field>
        <field name="model_id" ref="rounak_erp.model_res_partner"/>
        <field name="state">code</field>
        <field name="code">model._cron_rounak_overdue_check()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
