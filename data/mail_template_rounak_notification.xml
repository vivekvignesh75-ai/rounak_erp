<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="mail_template_rounak_notification" model="mail.template">
        <field name="name">Rounak: Notification Email</field>
        <field name="model_id" ref="rounak_erp.model_rounak_notification"/>
        <field name="subject">{{ object.title }}</field>
        <field name="email_from">{{ (object.env.company.email or 'noreply@rounakcomputers.com') }}</field>
        <field name="email_to">{{ object.user_id.email }}</field>
        <field name="body_html"><![CDATA[
<div style="max-width:600px;margin:0 auto;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">
    <div style="background-color:#1B2A4A;padding:16px 24px;">
        <span style="color:#ffffff;font-size:18px;font-weight:600;">Rounak Computers</span>
    </div>
    <div style="padding:24px;border:1px solid #EDEBE9;border-top:none;">
        <h2 style="color:#1B2A4A;font-size:16px;margin:0 0 12px;">{{ object.title }}</h2>
        <div style="color:#323130;font-size:14px;line-height:1.6;">
            {{ object.body or '' }}
        </div>
        <hr style="border:none;border-top:1px solid #EDEBE9;margin:20px 0;"/>
        <p style="color:#605E5C;font-size:12px;margin:0;">
            You are receiving this because of your notification preferences.
            <br/>To manage preferences, visit your portal settings.
        </p>
    </div>
    <div style="background-color:#F3F2F1;padding:12px 24px;text-align:center;">
        <span style="color:#605E5C;font-size:11px;">
            © {{ object.env.company.name }} — {{ object.env.company.city or 'Dubai, UAE' }}
        </span>
    </div>
</div>
]]></field>
    </record>
</odoo>
